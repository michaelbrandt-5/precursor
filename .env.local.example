# ────────────────────────────────────────────────────────────
# Precursor · Environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
# ────────────────────────────────────────────────────────────

# Public site URL (used for metadata, OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (Phase 1) ──────────────────────────────────────
# Create project at https://supabase.com → copy from Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Phase 3 — resume parsing, score drafting) ───
# Create key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Resend (Phase 4 — transactional + weekly digest) ───────
# Create key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@precursorindex.com

# ── Posthog (analytics) ────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Cron secret (Vercel Cron → weekly recompute + digest) ──
CRON_SECRET=
